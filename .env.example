# FieldPulse — Environment Variables
# Copy this file to .env and fill in your values

# ── App ──
VITE_APP_NAME=FieldPulse
VITE_APP_TAGLINE=Crew Dashboard

# ── Server ──
PORT=3001

# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fieldpulse
DB_USER=postgres
DB_PASSWORD=

# ── Auth ──
# REQUIRED: Change this to a long random string before deploying.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=fieldpulse-change-me-in-production

# ── CORS ──
# Comma-separated list of allowed origins.
# Default covers local dev. Extend if testing on iPad with your LAN IP.
# Example: http://localhost:5173,http://192.168.1.100:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Weather (optional) ──
# Sign up at https://openweathermap.org (free tier) to enable real weather data.
# Without this, the app uses simulated weather for testing.
VITE_WEATHER_API_KEY=
