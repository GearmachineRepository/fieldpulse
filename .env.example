# CruPoint — Environment Variables
# Copy this file to .env and fill in your values

# ── App ──
VITE_APP_NAME=CruPoint
VITE_APP_TAGLINE=Crew Dashboard

# ── Server ──
PORT=3001

# ── Database ──
# For local PostgreSQL:
#   DB_HOST=localhost
#   DB_PORT=5432
#   DB_NAME=crupoint
#
# For Supabase (use pooled connection on port 6543):
#   DB_HOST=db.<project-ref>.supabase.co
#   DB_PORT=6543
#   DB_NAME=postgres
#   DB_USER=postgres.<project-ref>
#   DB_SSL=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crupoint
DB_USER=postgres
DB_PASSWORD=
DB_SSL=

# ── Supabase (required for Auth, Storage, RLS) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ──
# REQUIRED: Change this to a long random string before deploying.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=crupoint-change-me-in-production

# ── Company ──
CompanyCode=

# ── CORS ──
# Comma-separated list of allowed origins.
# Default covers local dev. Extend if testing on iPad with your LAN IP.
# Example: http://localhost:5173,http://192.168.1.100:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Weather (optional) ──
# Sign up at https://openweathermap.org (free tier) to enable real weather data.
# Without this, the app uses simulated weather for testing.
VITE_WEATHER_API_KEY=

# ── Sentry (optional) ──
NODE_ENV=development
SENTRY_DSN=
VITE_SENTRY_DSN=
