# ═══════════════════════════════════════════
# App Branding — change these to rename the app
# ═══════════════════════════════════════════
VITE_APP_NAME=FieldPulse
VITE_APP_TAGLINE=Field Manager

# ═══════════════════════════════════════════
# Database — Local PostgreSQL
# ═══════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fieldpulse
DB_USER=postgres
DB_PASSWORD=

# ═══════════════════════════════════════════
# Authentication — JWT secret key
# IMPORTANT: Change this before deploying!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ═══════════════════════════════════════════
JWT_SECRET=change-me-before-production

# ═══════════════════════════════════════════
# Weather API — sign up at openweathermap.org
# Leave blank to use simulated weather
# ═══════════════════════════════════════════
VITE_WEATHER_API_KEY=

# ═══════════════════════════════════════════
# Server
# ═══════════════════════════════════════════
PORT=3001
