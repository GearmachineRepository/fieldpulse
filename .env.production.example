# ═══════════════════════════════════════════
# CruPoint — Production Environment
# ═══════════════════════════════════════════

NODE_ENV=production
PORT=3001

# ── App Branding ──
VITE_APP_NAME=CruPoint
VITE_APP_TAGLINE=Field Manager

# ── Database (managed PostgreSQL from Railway/Render) ──
DB_HOST=<your-db-host>
DB_PORT=5432
DB_NAME=crupoint
DB_USER=<your-db-user>
DB_PASSWORD=<your-db-password>

# ── Auth ──
# REQUIRED: Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Company ──
CompanyCode=CRUPOINT-A1B2

# ── CORS ──
ALLOWED_ORIGINS=https://crupoint.com,https://www.crupoint.com

# ── Weather API (OpenWeatherMap) ──
VITE_WEATHER_API_KEY=

# ── Error Tracking (Sentry — optional) ──
SENTRY_DSN=
VITE_SENTRY_DSN=
